# Copy to .env.hml and fill test values
# cp .env.hml.example .env.hml

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=etl_hml_db
POSTGRES_USER=etl_hml_user
POSTGRES_PASSWORD=change_me_hml

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me_hml
MINIO_BUCKET=etl-files-hml
MINIO_SECURE=false

# Notifier
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ETL Config
ETL_SCHEDULE_HOUR=18
ETL_SCHEDULE_MINUTE=0
ETL_TIMEZONE=America/Sao_Paulo
ETL_SOURCE_API_URL=https://drive.google.com/drive/folders/1EmP3eLMgdxeIgckyjlZPiBHY6GHo3Eqa?usp=sharing
ETL_SOURCE_API_KEY=
BAD_ROW_THRESHOLD_PCT=5.0
MAX_RETRIES=3

# Alerts
FLAG_FILE_DIR=/app/alerts
