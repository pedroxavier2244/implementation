# Copy this file to .env and fill in all values before running.
# cp .env.example .env

# PostgreSQL (local)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=etl_db
POSTGRES_USER=etl_user
POSTGRES_PASSWORD=change_me
POSTGRES_SSLMODE=disable

# PostgreSQL (Neon — substituir os valores acima por estes)
# POSTGRES_HOST=ep-xxxxx.us-east-2.aws.neon.tech
# POSTGRES_PORT=5432
# POSTGRES_DB=nomedobanco
# POSTGRES_USER=usuario
# POSTGRES_PASSWORD=senha
# POSTGRES_SSLMODE=require

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me
MINIO_BUCKET=etl-files
MINIO_SECURE=false

# ETL Config
BAD_ROW_THRESHOLD_PCT=5.0
MAX_RETRIES=3

# CNPJ Verification
CNPJ_CACHE_TTL_DAYS=30
BRASILAPI_TIMEOUT=10
CNPJ_VERIFY_BATCH_SIZE=300
